rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /recepciones/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /formularios-muestreo/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /plantillas-muestreo/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /muestreos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
